# 실제 API 키와 로컬 CSV 경로는 .env.local에만 입력합니다.

# 제출용 익명화 모드
# true이면 UI에서 실제 학교명, 주소, 전화번호, 홈페이지, 구체 지역명을 표시하지 않습니다.
NEXT_PUBLIC_DEMO_ANONYMIZE=true

# 데이터 버전
# v3-public: 제출용 공개 공공데이터 기반 1단계 지수
# v3-scenario: 확장진단 시나리오 점수 검증용
# v3-dev: 개발·검증용
NEXT_PUBLIC_DATA_VERSION=v3-public

# 확장진단 시나리오 데이터는 메인 지수에 반영하지 않습니다.
NEXT_PUBLIC_INCLUDE_SCENARIO_DATA=false

# NEIS 교육정보 개방 포털
# 현재 학교기본정보 수집은 키 없이도 동작합니다. 발급 키가 있으면 입력하세요.
NEIS_API_KEY=

# 공공데이터포털 표준데이터 API
# 전국초중등학교위치표준데이터 전체 조회에 사용합니다.
DATA_GO_KR_SERVICE_KEY=
TARGET_EDU_OFFICE_CODE=B10
TARGET_SIDO=서울특별시
TARGET_DISTRICT=노원구

# 학교알리미
# 학생 수, 교원 수, 학급 수 공시정보 자동 수집에 사용합니다.
# 2026년 공시 공개 전에는 기본값으로 전년도 공시를 조회합니다.
SCHOOLINFO_API_KEY=
SCHOOLINFO_PBAN_YEAR=
SCHOOLINFO_PUBLIC_CSV_PATH=

# 교육통계/학교 시설/정보화/AI 교육 관련 실제 공개자료 CSV
EDU_STATS_CSV_PATH=
SCHOOL_FACILITY_CSV_PATH=
DIGITAL_INFRA_CSV_PATH=
AI_PROGRAM_CSV_PATH=
TEACHER_TRAINING_CSV_PATH=

# 지역 지원 접근성 보조 데이터
AI_CENTER_CSV_PATH=
SW_AI_CAMP_CSV_PATH=
PUBLIC_LEARNING_CENTER_CSV_PATH=
